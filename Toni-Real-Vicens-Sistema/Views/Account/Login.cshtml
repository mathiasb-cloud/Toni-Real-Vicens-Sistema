@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Sistema Psicopedagógico</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            overflow: hidden;
            width: 100%;
            max-width: 400px;
        }

        .login-header {
            background-color: #ffffff;
            padding: 30px;
            text-align: center;
        }

            .login-header i {
                font-size: 50px;
                color: #764ba2;
            }
    </style>
</head>
<body>

    <div class="container">
        <div class="login-card mx-auto">
            <div class="login-header">
                <i class="bi bi-person-circle"></i>
                <h4 class="mt-2 fw-bold">BIENVENIDO</h4>
                <p class="text-muted small">Ingresa tus credenciales para acceder</p>
            </div>
            <div class="card-body bg-white p-4">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2 small">
                        <i class="bi bi-exclamation-triangle me-2"></i> @ViewBag.Error
                    </div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Correo Electrónico</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope"></i></span>
                            <input type="email" name="correo" class="form-control bg-light border-start-0" placeholder="ejemplo@correo.com" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold">Contraseña</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock"></i></span>
                            <input type="password" name="pass" class="form-control bg-light border-start-0" placeholder="********" required />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2 shadow-sm">
                        INICIAR SESIÓN
                    </button>
                </form>
            </div>
            <div class="card-footer bg-light border-0 text-center py-3">
                <small class="text-muted">&copy; 2026 - Sistema de Gestión Escolar</small>
            </div>
        </div>
    </div>

</body>
</html>