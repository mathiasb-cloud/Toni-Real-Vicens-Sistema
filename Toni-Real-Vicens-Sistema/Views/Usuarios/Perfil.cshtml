@model Toni_Real_Vicens_Sistema.Models.Usuario

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg" style="border-radius: 20px;">
                <div class="card-header border-0 py-4 text-white"
                     style="background: linear-gradient(135deg, #891c75 0%, #4a0f3f 100%); border-radius: 20px 20px 0 0;">
                    <h4 class="mb-0 text-center fw-bold text-uppercase">
                        <i class="bi bi-person-badge-fill me-2"></i> Mi Perfil
                    </h4>
                </div>
                <div class="card-body p-5 bg-white">
                    @if (ViewBag.IsAdmin == true)
                    {
                        <div class="alert alert-warning border-0 shadow-sm mb-4">
                            <i class="bi bi-shield-lock-fill me-2"></i>
                            Esta es una cuenta de <strong>Administrador Maestro</strong>. Los cambios de seguridad se gestionan directamente en la consola de Firebase.
                        </div>
                    }

                    <form asp-action="Perfil" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="row g-4">
                            <div class="col-md-4">
                                <label class="form-label fw-bold text-secondary small">Nombre</label>
                                <input asp-for="Nombre" class="form-control border-0 bg-light" readonly="@(ViewBag.IsAdmin == true)" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold text-secondary small">Apellido</label>
                                <input asp-for="Apellido" class="form-control border-0 bg-light" readonly="@(ViewBag.IsAdmin == true)" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold text-secondary small">Cargo</label>
                                <input asp-for="Cargo" class="form-control border-0 bg-light" readonly />
                            </div>
                        </div>

                        @if (ViewBag.IsAdmin != true)
                        {
                            <div class="d-grid mt-5">
                                <button type="submit" class="btn btn-lg text-white shadow" style="background: #891c75; border-radius: 12px;">
                                    Actualizar mis Datos <i class="bi bi-save ms-2"></i>
                                </button>
                            </div>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>