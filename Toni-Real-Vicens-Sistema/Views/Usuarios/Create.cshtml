@model Toni_Real_Vicens_Sistema.Models.Usuario

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg" style="border-radius: 20px;">
                <div class="card-header border-0 py-4 text-white"
                     style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 20px 20px 0 0;">
                    <h4 class="mb-0 text-center fw-bold text-uppercase tracking-wider">
                        <i class="bi bi-person-plus-fill me-2"></i> Registro de Nuevo Usuario
                    </h4>
                </div>

                <div class="card-body p-5 bg-white">
                    <form asp-action="Create" method="post">
                        <div class="row g-4">
                            <div class="col-md-4">
                                <label class="form-label fw-bold text-secondary small">Nombre</label>
                                <input asp-for="Nombre" class="form-control form-control-lg border-0 bg-light" placeholder="Ej. Juan" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold text-secondary small">Primer Apellido</label>
                                <input asp-for="Apellido" class="form-control form-control-lg border-0 bg-light" placeholder="Ej. Pérez" required />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold text-secondary small">Segundo Apellido</label>
                                <input asp-for="SegundoApellido" class="form-control form-control-lg border-0 bg-light" placeholder="Ej. Gómez" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small">Número de Celular</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0">+51</span>
                                    <input asp-for="Telefono" type="tel" class="form-control form-control-lg border-0 bg-light" placeholder="987654321" required />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small">Cargo / Función</label>
                                <select asp-for="Cargo" class="form-select form-select-lg border-0 bg-light" required>
                                    <option value="Psicólogo">Psicólogo</option>
                                    <option value="Director">Director</option>
                                    <option value="Tutor">Tutor</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small">Correo Institucional</label>
                                <input asp-for="Correo" type="email" class="form-control form-control-lg border-0 bg-light" placeholder="usuario@colegio.edu" required />
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-bold text-secondary small">Contraseña de Acceso</label>
                                <div class="input-group">
                                    <input asp-for="Contrasena" type="password" id="passInput" class="form-control form-control-lg border-0 bg-light" placeholder="Mínimo 6 caracteres" required />
                                    <button class="btn btn-light border-0" type="button" onclick="togglePass()">
                                        <i class="bi bi-eye" id="toggleIcon"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5">
                            <a asp-action="Index" class="btn btn-link text-decoration-none text-muted fw-bold">
                                <i class="bi bi-arrow-left"></i> Volver al listado
                            </a>
                            <button type="submit" class="btn btn-lg px-5 text-white shadow"
                                    style="background: #764ba2; border-radius: 12px;">
                                Guardar Usuario <i class="bi bi-check2-circle ms-2"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function togglePass() {
        const passInput = document.getElementById('passInput');
        const icon = document.getElementById('toggleIcon');
        if (passInput.type === "password") {
            passInput.type = "text";
            icon.className = "bi bi-eye-slash";
        } else {
            passInput.type = "password";
            icon.className = "bi bi-eye";
        }
    }
</script>