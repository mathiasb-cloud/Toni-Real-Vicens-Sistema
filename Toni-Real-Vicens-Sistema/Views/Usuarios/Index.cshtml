@model IEnumerable<Toni_Real_Vicens_Sistema.Models.Usuario>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color: #4a5568;">Gestión de Personal</h2>
        <a asp-action="Create" class="btn text-white px-4 py-2 shadow-sm" style="background: #891c75; border-radius: 10px;">
            <i class="bi bi-plus-lg me-2"></i> Nuevo Usuario
        </a>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 15px;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0 text-secondary small">USUARIO</th>
                        <th class="py-3 border-0 text-secondary small">CARGO</th>
                        <th class="py-3 border-0 text-secondary small">CORREO / TEL</th>
                        <th class="py-3 border-0 text-secondary small">ESTADO</th>
                        <th class="py-3 border-0 text-secondary small text-center">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                                         style="width: 40px; height: 40px; background: #fce7f3; color: #891c75 !important; font-weight: bold;">
                                        @item.Nombre[0]@item.Apellido[0]
                                    </div>
                                    <div>
                                        <span class="fw-bold d-block text-dark">@item.Nombre @item.Apellido</span>
                                        <small class="text-muted">ID: @item.Id.Substring(0, 5)...</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge rounded-pill px-3 py-2" style="background: #f3f4f6; color: #4b5563;">
                                    @item.Cargo
                                </span>
                            </td>
                            <td class="text-secondary">
                                <div class="small">@item.Correo</div>
                                <div class="text-muted small">@item.Telefono</div>
                            </td>
                            <td>
                                @if (item.IsActivo)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3">Inactivo</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    @if (item.Cargo != "Administrador")
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-light btn-sm rounded-circle shadow-sm" title="Editar">
                                            <i class="bi bi-pencil text-primary"></i>
                                        </a>

                                        <button type="button"
                                                onclick="confirmarToggle('@item.Id', '@item.Nombre', '@item.IsActivo.ToString()')"
                                                class="btn btn-light btn-sm rounded-circle shadow-sm"
                                                title="@(item.IsActivo ? "Desactivar" : "Activar")">
                                            <i class="bi bi-power @(item.IsActivo ? "text-danger" : "text-success")"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="badge bg-dark-subtle text-dark border px-2" style="font-size: 0.7rem;">
                                            <i class="bi bi-shield-lock-fill me-1"></i> PROTEGIDO
                                        </span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const accion = '@TempData["Accion"]';
        const error = '@TempData["Error"]';

        
        if (accion === "creado") {
            Swal.fire({
                title: '¡Excelente!',
                text: 'El usuario ha sido registrado correctamente.',
                icon: 'success',
                confirmButtonColor: '#891c75'
            });
        } else if (accion === "editado") {
            Swal.fire({
                title: 'Actualizado',
                text: 'Los cambios se guardaron con éxito.',
                icon: 'success',
                confirmButtonColor: '#891c75'
            });
        }

        if (error) {
            Swal.fire({
                title: 'Acceso Protegido',
                text: error,
                icon: 'warning',
                confirmButtonColor: '#891c75'
            });
        }

        
        function confirmarToggle(id, nombre, estadoActual) {
            const esActivo = estadoActual.toLowerCase() === 'true';
            const textoAccion = esActivo ? 'desactivar' : 'activar';
            const colorConfirm = esActivo ? '#d33' : '#891c75';

            Swal.fire({
                title: `¿Confirmas ${textoAccion}?`,
                text: `Vas a ${textoAccion} al usuario ${nombre}.`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: colorConfirm,
                cancelButtonColor: '#6c757d',
                confirmButtonText: `Sí, ${textoAccion}`,
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Usuarios/ToggleEstado', { id: id }, function(res) {
                        if(res.success) {
                            Swal.fire({
                                title: '¡Listo!',
                                text: `El usuario ha sido ${res.nuevoEstado ? 'activado' : 'desactivado'}.`,
                                icon: 'success',
                                confirmButtonColor: '#891c75'
                            }).then(() => location.reload());
                        } else {
                            Swal.fire('Error', res.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}