@{
    ViewData["Title"] = "Trabajando en ello";
    
}

<div class="coming-soon-container d-flex align-items-center justify-content-center">
    <div class="text-center p-5 card shadow-lg animated-card" style="border-radius: 30px; border: none; max-width: 600px; background: rgba(255,255,255,0.9); backdrop-filter: blur(10px);">

        <div class="animation-interfaz mb-4">
            <svg width="150" height="150" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" style="stop-color:#891c75;stop-opacity:1" />
                        <stop offset="100%" style="stop-color:#6610f2;stop-opacity:1" />
                    </linearGradient>
                </defs>

                <g class="gear-rotate">
                    <path fill="url(#grad1)" d="M90.3,53.4l-6.2-1.2c-0.6-2.1-1.4-4.1-2.5-6l3.9-5.1c0.9-1.2,0.8-2.9-0.3-4l-5.7-5.7c-1.1-1.1-2.8-1.2-4-0.3l-5.1,3.9c-1.9-1.1-3.9-1.9-6-2.5l-1.2-6.2c-0.3-1.5-1.6-2.6-3.1-2.6h-8c-1.5,0-2.8,1.1-3.1,2.6l-1.2,6.2c-2.1,0.6-4.1,1.4-6,2.5l-5.1-3.9c-1.2-0.9-2.9-0.8-4,0.3l-5.7,5.7c-1.1,1.1-1.2,2.8-0.3,4l3.9,5.1c-1.1,1.9-1.9,3.9-2.5,6l-6.2,1.2C1.1,53.6,0,54.9,0,56.4v8c0,1.5,1.1,2.8,2.6,3.1l6.2,1.2c0.6,2.1,1.4,4.1,2.5,6l-3.9,5.1c-0.9,1.2-0.8,2.9,0.3,4l5.7,5.7c1.1,1.1,2.8,1.2,4,0.3l5.1-3.9c1.9,1.1,3.9,1.9,6,2.5l1.2,6.2c0.3,1.5,1.6,2.6,3.1,2.6h8c1.5,0,2.8-1.1,3.1-2.6l1.2-6.2c2.1-0.6,4.1-1.4,6-2.5l5.1,3.9c1.2,0.9,2.9,0.8,4-0.3l5.7-5.7c1.1-1.1,1.2-2.8,0.3-4l-3.9-5.1c1.1-1.9,1.9-3.9,2.5-6l6.2-1.2c1.5-0.3,2.6-1.6,2.6-3.1v-8C92.9,54.9,91.8,53.6,90.3,53.4z M46.5,71.1c-9.2,0-16.6-7.4-16.6-16.6c0-9.2,7.4-16.6,16.6-16.6S63.1,45.4,63.1,54.6C63.1,63.7,55.7,71.1,46.5,71.1z" />
                </g>

                <g class="hammer-swing">
                    <path fill="#2c3e50" d="M68.5,25.4L55.8,12.7c-1.1-1.1-2.8-1.1-3.9,0L41.2,23.4c-1.1,1.1-1.1,2.8,0,3.9L49,35.1l-15.6,15.6c-0.5,0.5-0.5,1.4,0,1.9l3.9,3.9c0.5,0.5,1.4,0.5,1.9,0L54.9,40.8l7.8,7.8c1.1,1.1,2.8,1.1,3.9,0l10.7-10.7c1.1-1.1,1.1-2.8,0-3.9L68.5,25.4z" />
                    <rect x="52" y="32" transform="matrix(0.7071 -0.7071 0.7071 0.7071 -12.1421 52.8579)" fill="#95a5a6" width="28" height="6" rx="2" />
                </g>

                <circle class="sparkle sp-1" cx="40" cy="40" r="2" fill="#ffeb3b" />
                <circle class="sparkle sp-2" cx="50" cy="35" r="1.5" fill="#ffeb3b" />
            </svg>
        </div>

        <h1 class="fw-bold mb-3 mt-2" style="color: #891c75; font-size: 2.5rem;">¡Estamos en Ello!</h1>
        <p class="text-muted fs-5 mb-4">
            Esta sección está bajo construcción activa por nuestro equipo de desarrollo.
            <br>
            <span class="fw-bold" style="color: #6610f2;">Próximamente</span> estará disponible para mejorar el flujo.
        </p>

        <div class="progress mb-4" style="height: 10px; border-radius: 5px; background-color: #e9ecef;">
            <div class="progress-bar progress-bar-striped progress-bar-animated"
                 role="progressbar"
                 style="width: 100%; background-color: #891c75;"
                 aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">
            </div>
        </div>

        <a href="javascript:history.back()" class="btn btn-lg rounded-pill px-5 text-white shadow-sm fw-bold"
           style="background: linear-gradient(135deg, #891c75 0%, #6610f2 100%); transition: transform 0.2s;">
            <i class="bi bi-arrow-left me-2"></i>Volver Atrás
        </a>
    </div>
</div>

@section Styles {
    <style>
        /* Contenedor principal que ocupa toda la pantalla */
        .coming-soon-container {
            min-height: 80vh; /* Ajusta según tu layout */
            background-color: #f8f9fa;
        }

        /* Animación de entrada de la tarjeta */
        .animated-card {
            animation: fadeInUp 0.8s ease-out;
        }

        /* --- KEYFRAMES DE LAS ANIMACIONES SVG --- */

        /* 1. Rotación Infinita del Engranaje */
        .gear-rotate {
            transform-origin: 46.5px 54.6px; /* Centro del engranaje */
            animation: rotateGear 4s linear infinite;
        }

        /* 2. Balanceo del Martillo Golpeando */
        .hammer-swing {
            transform-origin: 35px 55px; /* Mango del martillo */
            animation: swingHammer 1.5s ease-in-out infinite;
        }

        /* 3. Chispas que aparecen y desaparecen */
        .sparkle {
            opacity: 0;
            animation: sparkleOpacity 1.5s linear infinite;
        }

        .sp-2 {
            animation-delay: 0.2s;
        }

        /* Definición de Keyframes */
        @@keyframes rotateGear {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        @@keyframes swingHammer {
            0%, 100% {
                transform: rotate(0deg);
            }

            40% {
                transform: rotate(-25deg);
            }
            /* Levantar */
            50% {
                transform: rotate(10deg);
            }
            /* Golpear */
            60% {
                transform: rotate(0deg);
            }
            /* Rebote */
        }

        @@keyframes sparkleOpacity {
            0%, 45%, 60%, 100% {
                opacity: 0;
                transform: scale(0);
            }

            50% {
                opacity: 1;
                transform: scale(1.2);
            }
            /* Aparece en el golpe */
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Efecto Hover en el botón */
        .btn-lg:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(137, 28, 117, 0.3) !important;
        }
    </style>
}