@model Toni_Real_Vicens_Sistema.Models.FichaDiagnostica
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container mt-4">
    <div class="card mb-4 border-info shadow-sm">
        <div class="card-body bg-light">
            <div class="row text-center small">
                <div class="col-md-3 border-end"><strong>Estudiante:</strong><br>@ViewBag.AlumnoNombre</div>
                <div class="col-md-2 border-end"><strong>DNI:</strong><br>@ViewBag.DNI</div>
                <div class="col-md-2 border-end"><strong>Grado:</strong><br>@ViewBag.Grado</div>
                
                <div class="col-md-3 border-end"><strong>Psicólogo Asignado:</strong><br><span class="text-primary fw-bold">@ViewBag.Psicologo</span></div>
                <div class="col-md-2"><strong>Fecha de Ficha:</strong><br>@DateTime.Now.ToString("dd/MM/yyyy")</div>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4" id="fichaTab" role="tablist">
        <li class="nav-item">
            <button class="nav-link active fw-bold text-uppercase" data-bs-toggle="tab" data-bs-target="#aspecto-familiar">II. ASPECTO FAMILIAR</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold text-uppercase" data-bs-toggle="tab" data-bs-target="#aspecto-economico">III. ASPECTO LABORAL Y ECONÓMICO</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold text-uppercase" data-bs-toggle="tab" data-bs-target="#aspectos-vivienda">IV. ASPECTOS DE VIVIENDA</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold text-uppercase" data-bs-toggle="tab" data-bs-target="#aspectos-salud">V. ASPECTOS DE SALUD</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold text-uppercase" data-bs-toggle="tab" data-bs-target="#aspectos-alimentacion">VI. ASPECTOS DE ALIMENTACIÓN</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold text-uppercase" data-bs-toggle="tab" data-bs-target="#aspecto-academico">VII. ASPECTO ACADÉMICO</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold text-uppercase" data-bs-toggle="tab" data-bs-target="#aspecto-emocional">VIII. ASPECTO EMOCIONAL</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold text-uppercase" data-bs-toggle="tab" data-bs-target="#aspecto-social">IX. ASPECTO SOCIAL</button>
        </li>
        <li class="nav-item">
            <button class="nav-link fw-bold text-uppercase" data-bs-toggle="tab" data-bs-target="#recursos-personales">X. RECURSOS PERSONALES</button>
        </li>
    </ul>

    <form asp-action="Create" method="post">
        @* Datos de vinculación ocultos *@
        <input type="hidden" asp-for="AlumnoId" />
        <input type="hidden" asp-for="CitaId" />
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="EsFinalizada" id="inputEsFinalizada" />
        <input type="hidden" asp-for="FuenteInformacion" />

        <div class="tab-content border p-4 bg-white shadow-sm rounded">

            <div class="tab-pane fade show active" id="aspecto-familiar">

                <div class="mb-5">
                    <h6 class="text-primary fw-bold text-uppercase"><i class="fas fa-users me-2"></i>2.1 Red familiar del estudiante:</h6>
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover mt-2 align-middle">
                            <thead class="table-dark small text-center">
                                <tr>
                                    <th>Nombre y Apellido</th>
                                    <th>Parentesco</th>
                                    <th style="width: 100px;">Edad</th>
                                    <th>Grado Instrucción</th>
                                    <th>Ocupación</th>
                                    <th>Teléfono</th>
                                    <th style="width: 80px;">Acción</th>
                                </tr>
                            </thead>
                            <tbody id="tbodyRedFamiliar">
                                @if (Model.RedFamiliar != null && Model.RedFamiliar.Count > 0)
                                {
                                    for (int i = 0; i < Model.RedFamiliar.Count; i++)
                                    {
                                        <tr id="fila-@i">
                                            <td><input asp-for="RedFamiliar[i].NombreApellido" class="form-control" /></td>
                                            <td><input asp-for="RedFamiliar[i].Parentesco" class="form-control" /></td>
                                            <td><input asp-for="RedFamiliar[i].Edad" type="number" class="form-control" /></td>
                                            <td><input asp-for="RedFamiliar[i].GradoInstruccion" class="form-control" /></td>
                                            <td><input asp-for="RedFamiliar[i].Ocupacion" class="form-control" /></td>
                                            <td><input asp-for="RedFamiliar[i].Telefono" class="form-control" /></td>
                                            <td class="text-center">
                                                @if (i == 0)
                                                {
                                                    <button type="button" class="btn btn-outline-secondary" disabled><i class="fas fa-lock"></i></button>
                                                }
                                                else
                                                {
                                                    <button type="button" class="btn btn-danger btn-sm" onclick="eliminarFila(@i)"><i class="fas fa-trash"></i></button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr id="fila-0">
                                        <td><input name="RedFamiliar[0].NombreApellido" class="form-control" placeholder="Ej: Juan Pérez" /></td>
                                        <td><input name="RedFamiliar[0].Parentesco" class="form-control" placeholder="Ej: Padre" /></td>
                                        <td><input name="RedFamiliar[0].Edad" type="number" class="form-control" /></td>
                                        <td><input name="RedFamiliar[0].GradoInstruccion" class="form-control" /></td>
                                        <td><input name="RedFamiliar[0].Ocupacion" class="form-control" /></td>
                                        <td><input name="RedFamiliar[0].Telefono" class="form-control" /></td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-outline-secondary" disabled><i class="fas fa-lock"></i></button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <button type="button" class="btn btn-dark btn-sm shadow-sm mt-1" onclick="addFila()">
                        <i class="fas fa-plus-circle"></i> Agregar integrante
                    </button>
                </div>

                <div class="mb-5">
                    <h6 class="text-primary fw-bold text-uppercase">2.2 ¿Con quién vive actualmente el estudiante?</h6>
                    <div class="row mt-3 g-3 ms-1">
                        <div class="col-md-3"><div class="form-check"><input type="checkbox" asp-for="ViveAmbosPadres" class="form-check-input" /> <label class="form-check-label">Ambos padres</label></div></div>
                        <div class="col-md-3"><div class="form-check"><input type="checkbox" asp-for="ViveSoloMadre" class="form-check-input" /> <label class="form-check-label">Solo madre</label></div></div>
                        <div class="col-md-3"><div class="form-check"><input type="checkbox" asp-for="ViveSoloPadre" class="form-check-input" /> <label class="form-check-label">Solo padre</label></div></div>
                        <div class="col-md-3">
                            <div class="form-check d-flex align-items-center">
                                <input type="checkbox" asp-for="ViveHermanos" class="form-check-input me-2" />
                                <label class="me-2">Hermanos (N°):</label>
                                <input asp-for="NumeroHermanos" class="form-control form-control-sm d-inline-block w-25" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-5 p-3 bg-light rounded border-start border-primary border-4">
                    <h6 class="text-primary fw-bold text-uppercase">2.3 La relación con sus familiares es:</h6>
                    <div class="d-flex flex-wrap gap-4 mt-3 ms-2">
                        <div class="form-check"><input type="radio" asp-for="RelacionFamiliar" value="Armoniosa" class="form-check-input" /> <label class="form-check-label">Armoniosa</label></div>
                        <div class="form-check"><input type="radio" asp-for="RelacionFamiliar" value="Regularmente Armoniosa" class="form-check-input" /> <label class="form-check-label">Regularmente Armoniosa</label></div>
                        <div class="form-check"><input type="radio" asp-for="RelacionFamiliar" value="Conflictiva" class="form-check-input" /> <label class="form-check-label">Conflictiva</label></div>
                        <div class="form-check"><input type="radio" asp-for="RelacionFamiliar" value="Violenta" class="form-check-input" /> <label class="form-check-label text-danger fw-bold">Violenta</label></div>
                    </div>
                </div>

                <div class="mb-5">
                    <h6 class="text-primary fw-bold text-uppercase">2.4 ¿Qué problemas se presentan en el hogar del estudiante?</h6>
                    <div class="row mt-3 ms-1 g-3">
                        <div class="col-md-3"><div class="form-check"><input asp-for="ProblemaViolencia" class="form-check-input" /> <label class="form-check-label">Violencia</label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="ProblemaComunicacion" class="form-check-input" /> <label class="form-check-label">Comunicación</label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="ProblemaEconomico" class="form-check-input" /> <label class="form-check-label">Económico</label></div></div>
                        <div class="col-md-3"><div class="form-check"><input asp-for="ProblemaSalud" class="form-check-input" /> <label class="form-check-label">Salud</label></div></div>
                    </div>
                </div>

                <div class="mb-5">
                    <h6 class="text-primary fw-bold text-uppercase">2.5 Generalmente, la comunicación en el hogar se ve influenciada por:</h6>
                    <div class="row mt-3 ms-1 g-3">
                        <div class="col-md-3"><div class="form-check"><input type="checkbox" asp-for="InfluenciaFaltaTiempo" class="form-check-input" /> <label class="form-check-label">Falta de tiempo de padres</label></div></div>
                        <div class="col-md-3"><div class="form-check"><input type="checkbox" asp-for="InfluenciaDesinteres" class="form-check-input" /> <label class="form-check-label">Desinterés / Indiferencia</label></div></div>
                        <div class="col-md-3"><div class="form-check"><input type="checkbox" asp-for="InfluenciaFaltaComprension" class="form-check-input" /> <label class="form-check-label">Falta de comprensión</label></div></div>
                        <div class="col-md-3"><div class="form-check"><input type="checkbox" asp-for="InfluenciaTemor" class="form-check-input" /> <label class="form-check-label">Temor / Miedo</label></div></div>
                    </div>
                </div>

                <div class="mb-5">
                    <h6 class="text-primary fw-bold text-uppercase">2.6 ¿Quién apoya al estudiante para realizar sus tareas escolares?</h6>
                    <div class="d-flex flex-wrap gap-4 mt-3 ms-2">
                        <div class="form-check"><input asp-for="ApoyoMama" class="form-check-input" /> <label class="form-check-label">Mamá</label></div>
                        <div class="form-check"><input asp-for="ApoyoPapa" class="form-check-input" /> <label class="form-check-label">Papá</label></div>
                        <div class="form-check"><input asp-for="ApoyoHermanos" class="form-check-input" /> <label class="form-check-label">Hermanos</label></div>
                        <div class="form-check"><input asp-for="ApoyoTios" class="form-check-input" /> <label class="form-check-label">Tíos</label></div>
                        <div class="form-check"><input asp-for="ApoyoAbuelos" class="form-check-input" /> <label class="form-check-label">Abuelos</label></div>
                        <div class="form-check"><input asp-for="ApoyoSolo" class="form-check-input" /> <label class="form-check-label">Solo</label></div>
                    </div>
                </div>

            </div>






            <div class="tab-pane fade" id="aspecto-economico">

                <div class="mb-4">
                    <h6 class="text-primary fw-bold text-uppercase">3.1 ¿El padre del estudiante trabaja?</h6>
                    <div class="row align-items-center">
                        <div class="col-md-3">
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input type="radio" asp-for="PadreTrabaja" value="true" class="form-check-input radio-toggle" data-target="grupo-padre" />
                                    <label class="form-check-label">SÍ</label>
                                </div>
                                <div class="form-check">
                                    <input type="radio" asp-for="PadreTrabaja" value="false" class="form-check-input radio-toggle" data-target="grupo-padre" />
                                    <label class="form-check-label">NO</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <input asp-for="PadreDondeTrabaja" class="form-control form-control-sm grupo-padre" placeholder="¿Dónde trabaja?" />
                        </div>
                        <div class="col-md-5">
                            <input asp-for="PadreQueTrabaja" class="form-control form-control-sm grupo-padre" placeholder="¿En qué trabaja?" />
                        </div>
                    </div>
                </div>

                <hr />

                <div class="mb-4">
                    <h6 class="text-primary fw-bold text-uppercase">3.2 ¿La madre del estudiante trabaja?</h6>
                    <div class="row align-items-center">
                        <div class="col-md-3">
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input type="radio" asp-for="MadreTrabaja" value="true" class="form-check-input radio-toggle" data-target="grupo-madre" />
                                    <label class="form-check-label">SÍ</label>
                                </div>
                                <div class="form-check">
                                    <input type="radio" asp-for="MadreTrabaja" value="false" class="form-check-input radio-toggle" data-target="grupo-madre" />
                                    <label class="form-check-label">NO</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <input asp-for="MadreDondeTrabaja" class="form-control form-control-sm grupo-madre" placeholder="¿Dónde trabaja?" />
                        </div>
                        <div class="col-md-5">
                            <input asp-for="MadreQueTrabaja" class="form-control form-control-sm grupo-madre" placeholder="¿En qué trabaja?" />
                        </div>
                    </div>
                </div>

                <hr />

                <div class="mb-4">
                    <h6 class="text-primary fw-bold text-uppercase">3.3 Ingreso familiar mensual:</h6>
                    <div class="d-flex flex-wrap gap-4 mt-2 ms-2">
                        <div class="form-check"><input type="radio" asp-for="IngresoFamiliarMensual" value="Menos de 200" class="form-check-input" /> <label class="form-check-label text-secondary">Menos de S/ 200.00</label></div>
                        <div class="form-check"><input type="radio" asp-for="IngresoFamiliarMensual" value="200 a 500" class="form-check-input" /> <label class="form-check-label text-secondary">De S/ 200 a 500</label></div>
                        <div class="form-check"><input type="radio" asp-for="IngresoFamiliarMensual" value="500 a 1000" class="form-check-input" /> <label class="form-check-label text-secondary">De S/ 500 a 1000</label></div>
                        <div class="form-check"><input type="radio" asp-for="IngresoFamiliarMensual" value="Mas de 1000" class="form-check-input" /> <label class="form-check-label text-secondary">Más de 1000</label></div>
                    </div>
                </div>

                <div class="mb-4 p-3 bg-light rounded border">
                    <h6 class="text-primary fw-bold text-uppercase">3.4 ¿En qué gastos priorizan los padres del estudiante?</h6>
                    <div class="row mt-2 g-3 ms-1">
                        <div class="col-md-2"><div class="form-check"><input asp-for="GastoAlimentos" class="form-check-input" /> <label class="form-check-label small">Alimentos</label></div></div>
                        <div class="col-md-2"><div class="form-check"><input asp-for="GastoEducacion" class="form-check-input" /> <label class="form-check-label small">Educación</label></div></div>
                        <div class="col-md-2"><div class="form-check"><input asp-for="GastoRopa" class="form-check-input" /> <label class="form-check-label small">Ropa</label></div></div>
                        <div class="col-md-2"><div class="form-check"><input asp-for="GastoArtefactos" class="form-check-input" /> <label class="form-check-label small">Artefactos</label></div></div>
                        <div class="col-md-2"><div class="form-check"><input asp-for="GastoServicios" class="form-check-input" /> <label class="form-check-label small">Servicios</label></div></div>
                        <div class="col-md-2"><input asp-for="GastoOtros" class="form-control form-control-sm" placeholder="Otros..." /></div>
                    </div>
                </div>

                <hr />

                <div class="mb-4">
                    <h6 class="text-primary fw-bold text-uppercase">3.5 ¿El estudiante trabaja?</h6>
                    <div class="row align-items-center">
                        <div class="col-md-3">
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input type="radio" asp-for="EstudianteTrabaja" value="true" class="form-check-input radio-toggle" data-target="grupo-estudiante" />
                                    <label class="form-check-label">SÍ</label>
                                </div>
                                <div class="form-check">
                                    <input type="radio" asp-for="EstudianteTrabaja" value="false" class="form-check-input radio-toggle" data-target="grupo-estudiante" />
                                    <label class="form-check-label">NO</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <input asp-for="EstudianteDondeTrabaja" class="form-control form-control-sm grupo-estudiante" placeholder="¿Dónde trabaja?" />
                        </div>
                        <div class="col-md-5">
                            <input asp-for="EstudianteQueTrabaja" class="form-control form-control-sm grupo-estudiante" placeholder="¿En qué trabaja?" />
                        </div>
                    </div>
                </div>

                <div class="mb-4 p-3 border-start border-4 border-info bg-light rounded">
                    <h6 class="text-primary fw-bold text-uppercase">3.6 ¿Qué hace el estudiante con lo que gana?</h6>
                    <div class="d-flex flex-wrap gap-4 mt-2 ms-2">
                        <div class="form-check">
                            <input asp-for="DestinoDoyPadres" class="form-check-input grupo-estudiante" />
                            <label class="form-check-label small">Lo doy a mis padres</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="DestinoEducacion" class="form-check-input grupo-estudiante" />
                            <label class="form-check-label small">Educación</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="DestinoRopa" class="form-check-input grupo-estudiante" />
                            <label class="form-check-label small">Ropa</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="DestinoInternet" class="form-check-input grupo-estudiante" />
                            <label class="form-check-label small">Internet</label>
                        </div>
                        <div class="col-md-3">
                            <input asp-for="DestinoOtros" class="form-control form-control-sm grupo-estudiante" placeholder="Otros..." />
                        </div>
                    </div>
                </div>
            </div>













            <div class="tab-pane fade" id="aspectos-vivienda">
                <div class="row g-3">
                    <div class="col-md-4 border-end">
                        <h6 class="text-primary fw-bold text-uppercase small">4.1 La vivienda es:</h6>
                        <select asp-for="TipoVivienda" class="form-select form-select-sm">
                            <option value="">Seleccione...</option>
                            <option value="Propia">PROPIA</option>
                            <option value="Alquilada">ALQUILADA</option>
                            <option value="Otros">OTROS</option>
                        </select>
                    </div>
                    <div class="col-md-4 border-end">
                        <h6 class="text-primary fw-bold text-uppercase small">4.2 Material de vivienda:</h6>
                        <select asp-for="MaterialVivienda" class="form-select form-select-sm">
                            <option value="">Seleccione...</option>
                            <option value="Noble">NOBLE</option>
                            <option value="Adobe">ADOBE</option>
                            <option value="Madera">MADERA</option>
                            <option value="Otros">OTROS</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-primary fw-bold text-uppercase small">4.3 El piso es de:</h6>
                        <select asp-for="TipoPiso" class="form-select form-select-sm">
                            <option value="">Seleccione...</option>
                            <option value="Cerámica">CERÁMICA</option>
                            <option value="Cemento">CEMENTO</option>
                            <option value="Tierra">TIERRA</option>
                        </select>
                    </div>

                    <hr />

                    <h6 class="text-primary fw-bold text-uppercase small">4.4 La vivienda cuenta con: (colocar cantidades)</h6>
                    <div class="row g-2 text-center">
                        <div class="col"><label class="small">Cocina</label><input asp-for="CantCocina" type="number" class="form-control form-control-sm text-center" min="0" /></div>
                        <div class="col"><label class="small">Dormitorios</label><input asp-for="CantDormitorios" type="number" class="form-control form-control-sm text-center" min="0" /></div>
                        <div class="col"><label class="small">Comedor</label><input asp-for="CantComedor" type="number" class="form-control form-control-sm text-center" min="0" /></div>
                        <div class="col"><label class="small">Sala</label><input asp-for="CantSala" type="number" class="form-control form-control-sm text-center" min="0" /></div>
                        <div class="col"><label class="small">Baño</label><input asp-for="CantBano" type="number" class="form-control form-control-sm text-center" min="0" /></div>
                    </div>

                    <hr />

                    <div class="col-md-6 border-end">
                        <h6 class="text-primary fw-bold text-uppercase small">4.5 Cuenta con los servicios de:</h6>
                        <div class="row g-2">
                            <div class="col-4"><div class="form-check"><input asp-for="ServicioAgua" class="form-check-input" /> <label class="form-check-label small">Agua</label></div></div>
                            <div class="col-4"><div class="form-check"><input asp-for="ServicioLuz" class="form-check-input" /> <label class="form-check-label small">Luz</label></div></div>
                            <div class="col-4"><div class="form-check"><input asp-for="ServicioDesague" class="form-check-input" /> <label class="form-check-label small">Desagüe</label></div></div>
                            <div class="col-4"><div class="form-check"><input asp-for="ServicioCable" class="form-check-input" /> <label class="form-check-label small">Cable</label></div></div>
                            <div class="col-4"><div class="form-check"><input asp-for="ServicioInternet" class="form-check-input" /> <label class="form-check-label small">Internet</label></div></div>
                            <div class="col-4"><div class="form-check"><input asp-for="ServicioPlataformas" class="form-check-input" /> <label class="form-check-label small">Plataformas</label></div></div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h6 class="text-primary fw-bold text-uppercase small">4.6 En la casa del estudiante cuentan con:</h6>
                        <div class="row g-2">
                            <div class="col-4"><div class="form-check"><input asp-for="TieneTelevisor" class="form-check-input" /> <label class="form-check-label small">Televisor</label></div></div>
                            <div class="col-4"><div class="form-check"><input asp-for="TieneComputadora" class="form-check-input" /> <label class="form-check-label small">Computadora</label></div></div>
                            <div class="col-4"><div class="form-check"><input asp-for="TieneEquipoSonido" class="form-check-input" /> <label class="form-check-label small">Eq. Sonido</label></div></div>
