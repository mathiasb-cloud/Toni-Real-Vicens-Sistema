        </div>

        <div class="mt-5 p-4 bg-light border rounded text-center">
            <div class="d-flex justify-content-center gap-3">

                @* 1. AGREGAMOS UN ONCLICK PARA ASEGURAR QUE ES FALSE *@
                <button type="submit" onclick="document.getElementById('inputEsFinalizada').value='false'" class="btn btn-primary btn-lg px-4 shadow">
                    <i class="bi bi-save me-2"></i> GUARDAR AVANCE
                </button>

                <button type="button" onclick="confirmarFinalizacion()" class="btn btn-danger btn-lg px-4 shadow">
                    <i class="bi bi-check-circle-fill me-2"></i> FINALIZAR FICHA
                </button>

            </div>
            <p class="text-muted small mt-3">
                * "Guardar avance" permite seguir editando después (Estado: En Proceso). <br />
                * "Finalizar" bloquea la ficha (Estado: Atendida).
            </p>
        </div>

        
        <input type="hidden" asp-for="EsFinalizada" id="inputEsFinalizada" />
    </form>

   



</div>

@section Scripts {
    <script>
        let index = 1;
        function addFila() {
            const tbody = document.getElementById("tbodyRedFamiliar");
            const tr = document.createElement("tr");
            tr.id = `fila-${index}`;
            tr.className = "align-middle animate__animated animate__fadeIn";

            tr.innerHTML = `
                <td><input name="RedFamiliar[${index}].NombreApellido" class="form-control" /></td>
                <td><input name="RedFamiliar[${index}].Parentesco" class="form-control" /></td>
                <td><input name="RedFamiliar[${index}].Edad" type="number" class="form-control" /></td>
                <td><input name="RedFamiliar[${index}].GradoInstruccion" class="form-control" /></td>
                <td><input name="RedFamiliar[${index}].Ocupacion" class="form-control" /></td>
                <td><input name="RedFamiliar[${index}].Telefono" class="form-control" /></td>
                <td class="text-center">
                    <button type="button" class="btn btn-danger shadow-sm btn-delete" onclick="eliminarFila(${index})" title="Eliminar familiar">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </td>`;

            tbody.appendChild(tr);
            index++;
        }


        function confirmarFinalizacion() {
                if (confirm("¿Estás seguro de finalizar? Esto cambiará el estado a Atendida y no podrás editar más.")) {
                    document.getElementById('inputEsFinalizada').value = 'true';
                    // Enviamos el formulario manualmente
                    document.querySelector('form').submit();
                }
            }

        function eliminarFila(idx) {
            const fila = document.getElementById(`fila-${idx}`);
            if (fila) fila.remove();
        }

        function toggleInputs(grupo, habilitar) {
            
            const elementos = document.querySelectorAll(`.grupo-${grupo}`);

            elementos.forEach(el => {
                el.disabled = !habilitar;

                if (!habilitar) {
                    
                    if (el.type === "text" || el.type === "number") {
                        el.value = "";
                    }
                    
                    if (el.type === "checkbox") {
                        el.checked = false;
                    }
                }
            });
        }





                




        @if (Model.EsFinalizada)
        {
                <text>
                $(document).ready(function() {
                    $("input, select, textarea, button").prop("disabled", true);
                    $(".btn-danger, .btn-primary").hide(); 
                });
                </text>
        }










        document.addEventListener("DOMContentLoaded", function() {
            var mensaje = "@TempData["Mensaje"]";
            if (mensaje === "creado" || mensaje === "actualizado") {
                Swal.fire({
                    title: '¡Buen trabajo!',
                    text: 'El avance de la ficha se ha guardado correctamente.',
                    icon: 'success',
                    confirmButtonColor: '#3085d6',
                    confirmButtonText: 'Continuar'
                });
            }

            var error = "@TempData["Error"]";
            if (error) {
                Swal.fire('Error', error, 'error');
            }
        });

        
        function confirmarFinalizacion() {
            Swal.fire({
                title: '¿Estás seguro?',
                text: "No podrás editar esta ficha después de finalizarla.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Sí, finalizar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById("inputEsFinalizada").value = "true";
                    document.getElementById("inputEsFinalizada").closest('form').submit();
                }
            });
        }








        document.addEventListener("DOMContentLoaded", function() {
            
            var mensaje = "@TempData["Mensaje"]";

            
            if (mensaje && mensaje.trim() !== "") {
                Swal.fire({
                    title: '¡Buen trabajo!',
                    text: 'El avance de la ficha se ha guardado correctamente.',
                    icon: 'success',
                    timer: 2500, 
                    showConfirmButton: false,
                    borderRadius: '15px'
                });
            }

            var error = "@TempData["Error"]";
            if (error) {
                Swal.fire('Error', error, 'error');
            }
        });

        
        function confirmarFinalizacion() {
            Swal.fire({
                title: '¿Estás seguro?',
                text: "No podrás editar esta ficha después de finalizarla.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Sí, finalizar',
                cancelButtonText: 'Cancelar',
                borderRadius: '15px'
            }).then((result) => {
                if (result.isConfirmed) {
                    
                    document.getElementById("inputEsFinalizada").value = "true";
                    
                    document.getElementById("inputEsFinalizada").closest('form').submit();
                }
            });
        }

    </script>

    <style>
        .btn-delete {
            width: 35px;
            height: 35px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.2s;
        }

            .btn-delete:hover {
                transform: scale(1.1);
            }

        .form-check-input:checked {
            background-color: #0d6efd;
            border-color: #0d6efd;
        }
    </style>
}