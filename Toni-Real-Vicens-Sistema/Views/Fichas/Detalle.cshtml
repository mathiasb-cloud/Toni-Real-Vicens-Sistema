@model Toni_Real_Vicens_Sistema.Models.Alumno

@{
    ViewData["Title"] = "Expediente Psicologico de " + Model.Nombres;
}

<div class="container-fluid py-4" style="background-color: #f0f2f5; min-height: 100vh;">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" class="btn btn-white shadow-sm rounded-circle me-3">
            <i class="bi bi-arrow-left text-primary"></i>
        </a>
        <div>
            <h4 class="fw-bold mb-0">Expediente del Estudiante</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="#">Fichas</a></li>
                    <li class="breadcrumb-item active">@Model.Apellidos, @Model.Nombres</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-3 col-lg-4">
            <div class="card border-0 shadow-sm text-center p-4" style="border-radius: 20px;">
                <div class="mx-auto mb-3 avatar-large">
                    @Model.Nombres.Substring(0, 1)@Model.Apellidos.Substring(0, 1)
                </div>
                <h5 class="fw-bold mb-1">@Model.Nombres @Model.Apellidos</h5>
                <p class="text-muted small mb-3">DNI: @Model.DNI</p>

                <div class="d-grid gap-2">
                    <span class="badge bg-primary-soft text-primary p-2">@Model.Nivel</span>
                    <span class="badge rounded-pill bg-secondary">
                        @Model.Grado @(string.IsNullOrWhiteSpace(Model.Seccion) ? "" : "- Secc. " + Model.Seccion)
                    </span>
                </div>

                <hr class="my-4 opacity-25">

                <div class="text-start">
                    <label class="text-muted small text-uppercase fw-bold">Estado Académico</label>
                    <div class="d-flex align-items-center mt-2">
                        <div class="status-indicator @(Model.Estado == "Retirado" ? "bg-danger" : "bg-success")"></div>
                        <span class="ms-2">@(Model.Estado ?? "Regular")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-9 col-lg-8">
            <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <ul class="nav nav-pills nav-fill bg-light p-1 rounded-pill" id="pills-tab" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active rounded-pill" data-bs-toggle="pill" data-bs-target="#info-general"><i class="bi bi-person me-2"></i>Datos Generales</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link rounded-pill" data-bs-toggle="pill" data-bs-target="#fichas-academicas"><i class="bi bi-file-earmark-text me-2"></i>Fichas</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link rounded-pill" data-bs-toggle="pill" data-bs-target="#historial"><i class="bi bi-clock-history me-2"></i>Historial</button>
                        </li>
                    </ul>
                </div>

                <div class="card-body p-4">
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="info-general">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="p-3 border rounded-3 bg-light-subtle">
                                        <small class="text-muted d-block mb-1">Apellidos y Nombres</small>
                                        <span class="fw-bold text-dark">@Model.Apellidos, @Model.Nombres</span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="p-3 border rounded-3 bg-light-subtle">
                                        <small class="text-muted d-block mb-1">Documento de Identidad (DNI)</small>
                                        <span class="fw-bold text-dark">@Model.DNI</span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="p-3 border rounded-3 bg-light-subtle">
                                        <small class="text-muted d-block mb-1">Nivel Educativo</small>
                                        <span class="fw-bold text-dark">@Model.Nivel</span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="p-3 border rounded-3 bg-light-subtle">
                                        <small class="text-muted d-block mb-1">Grado</small>
                                        <span class="fw-bold text-dark">@Model.Grado</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="fichas-academicas">
                            <div class="row mb-3 g-2">
                                <div class="col-md-7">
                                    <input type="text" id="searchPsicologo" class="form-control form-control-sm rounded-pill shadow-sm" placeholder="🔍 Buscar por Psicólogo (Fuente)...">
                                </div>
                                <div class="col-md-5">
                                    <input type="date" id="filterFecha" class="form-control form-control-sm rounded-pill shadow-sm">
                                </div>
                            </div>

                            <div class="list-group list-group-flush" id="listaFichas">
                                @if (ViewBag.FichasDiagnosticas != null && ((List<Toni_Real_Vicens_Sistema.Models.FichaDiagnostica>)ViewBag.FichasDiagnosticas).Any())
                                {
                                    foreach (var ficha in (List<Toni_Real_Vicens_Sistema.Models.FichaDiagnostica>)ViewBag.FichasDiagnosticas)
                                    {
                                        <div class="list-group-item d-flex justify-content-between align-items-center py-3 px-0 ficha-row"
                                             data-psicologo="@(ficha.FuenteInformacion?.ToLower() ?? "no asignado")"
                                             data-fecha="@ficha.Fecha.ToString("yyyy-MM-dd")">
                                            <div class="d-flex align-items-center">
                                                <div class="icon-box bg-success-soft text-success me-3">
                                                    <i class="bi bi-journal-check"></i>
                                                </div>
                                                <div>
                                                    <h6 class="mb-0 fw-bold">Ficha Diagnóstica @ficha.AnioAcademico</h6>
                                                    <small class="text-muted">Psic: @(ficha.FuenteInformacion ?? "No asignado") | @ficha.Fecha.ToShortDateString()</small>
                                                </div>
                                            </div>
                                            <a asp-controller="Fichas" asp-action="VerFichaDetalle" asp-route-id="@ficha.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                                <i class="bi bi-eye-fill me-1"></i> Ver Ficha
                                            </a>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-center p-4">
                                        <p class="text-muted">No se encontraron fichas registradas para este alumno.</p>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="tab-pane fade" id="historial">
                            <div class="p-5 text-center">
                                <i class="bi bi-info-circle text-muted fs-1"></i>
                                <p class="mt-3 text-muted">El historial de matrículas anteriores se habilitará al finalizar el año escolar 2026.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Tus estilos originales se mantienen intactos */
    .avatar-large {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, #4e73df 0%, #224abe 100%);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        font-weight: bold;
    }

    .bg-primary-soft {
        background-color: rgba(78, 115, 223, 0.1);
    }

    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .bg-warning-soft {
        background-color: rgba(255, 193, 7, 0.1);
    }

    .status-indicator {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }

    .icon-box {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    .nav-pills .nav-link.active {
        background-color: #4e73df;
    }

    .btn-white {
        background: white;
        border: none;
    }
</style>

@section Scripts {
    <script>
        // Lógica de filtrado en tiempo real dentro de la lista
        document.getElementById('searchPsicologo').addEventListener('input', filtrar);
        document.getElementById('filterFecha').addEventListener('input', filtrar);

        function filtrar() {
            const psi = document.getElementById('searchPsicologo').value.toLowerCase();
            const fecha = document.getElementById('filterFecha').value;

            document.querySelectorAll('.ficha-row').forEach(row => {
                const matchPsi = row.dataset.psicologo.includes(psi);
                const matchFecha = fecha === "" || row.dataset.fecha === fecha;
                row.style.display = (matchPsi && matchFecha) ? "flex" : "none";
            });
        }
    </script>
}