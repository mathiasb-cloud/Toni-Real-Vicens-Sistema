@model List<Toni_Real_Vicens_Sistema.Models.Cita>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: #4a5568;">
                <i class="bi bi-calendar2-check-fill me-2" style="color: #764ba2;"></i> Gestión de Citas
            </h2>
            <p class="text-muted small mb-0">Monitoreo de sesiones y estados de atención psicopedagógica.</p>
        </div>
        <a asp-action="Create" class="btn text-white px-4 py-2 shadow-sm"
           style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px;">
            <i class="bi bi-plus-lg me-2"></i> Nueva Cita
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
        <div class="card-body p-3">
            <div class="row g-3 align-items-center">
                <div class="col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" id="searchInput" class="form-control border-0 shadow-none" placeholder="Buscar alumno...">
                    </div>
                </div>

                <div class="col-md-2">
                    <select id="filterTipo" class="form-select border-0 bg-light small fw-bold" style="border-radius: 8px;">
                        <option value="todos">Todos los Tipos</option>
                        <option value="Evaluación">Diagnóstica</option>
                        <option value="Seguimiento">Seguimiento</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <select id="filterEstado" class="form-select border-0 bg-light small fw-bold" style="border-radius: 8px;">
                        <option value="todos">Todos los Estados</option>
                        <option value="Programada">📅 Programadas</option>
                        <option value="Pendiente">⏳ En Proceso</option>
                        <option value="Atendida">✅ Finalizadas</option>
                        <option value="Ausente">❌ Ausentes</option>
                    </select>
                </div>

                <div class="col-md-5">
                    <div class="d-flex align-items-center gap-2">
                        <span class="small text-muted fw-bold text-nowrap">Desde:</span>
                        <input type="date" id="dateStart" class="form-control form-control-sm border-0 bg-light" style="border-radius: 8px;">
                        <span class="small text-muted fw-bold text-nowrap">Hasta:</span>
                        <input type="date" id="dateEnd" class="form-control form-control-sm border-0 bg-light" style="border-radius: 8px;">
                        <button id="clearDates" class="btn btn-sm btn-outline-secondary border-0" title="Limpiar fechas">
                            <i class="bi bi-x-circle"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>


    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 15px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="citasTable">
                <thead style="background-color: #f8faff;">
                    <tr>
                        <th class="ps-4 py-3 text-secondary small border-0">FECHA Y HORA</th>
                        <th class="py-3 text-secondary small border-0">ESTUDIANTE</th>
                        <th class="py-3 text-secondary small border-0">TIPO</th>
                        <th class="py-3 text-secondary small border-0">PSICÓLOGO</th>
                        <th class="py-3 text-secondary small border-0 text-center">ESTADO</th>
                        <th class="py-3 text-secondary small border-0 text-center">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cita in Model)
                    {
                        var nombreAlumno = ViewBag.NombresAlumnos.ContainsKey(cita.AlumnoId)
                        ? ViewBag.NombresAlumnos[cita.AlumnoId]
                        : "Desconocido";

                        <tr data-estado="@cita.Estado" data-tipo="@cita.Tipo" data-ticks="@(cita.FechaHora?.Ticks ?? 0)">
                            <td class="ps-4 text-dark fw-medium">
                                @cita.FechaHora?.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td><strong class="text-dark">@nombreAlumno</strong></td>
                            <td>
                                @if (cita.Tipo == "Evaluación")
                                {
                                    <span class="text-primary small fw-bold"><i class="bi bi-clipboard2-pulse me-1"></i>Diagnóstica</span>
                                }
                                else
                                {
                                    <span class="text-info small fw-bold"><i class="bi bi-arrow-repeat me-1"></i>Seguimiento</span>
                                }
                            </td>
                            <td><i class="bi bi-person-badge me-1"></i> @cita.Psicologo</td>

                            <td class="text-center">
                                @if (cita.Estado == "Atendida")
                                {
                                    <span class="badge px-3 py-2" style="background: #ebfbee; color: #2b8a3e; border-radius: 8px;">Finalizada</span>
                                }
                                else if (cita.Estado == "En Proceso")
                                {
                                    <span class="badge px-3 py-2" style="background: #e1f5fe; color: #0288d1; border-radius: 8px;">En Proceso</span>
                                }
                                else if (cita.Estado == "Ausente")
                                {
                                    <span class="badge px-3 py-2" style="background: #fff5f5; color: #e03131; border-radius: 8px;">Ausente</span>
                                }
                                else
                                {
                                    <span class="badge px-3 py-2" style="background: #fff9db; color: #f08c00; border-radius: 8px;">Programada</span>
                                }

                                @if (cita.FueReprogramada)
                                {
                                    <div class="mt-1">
                                        <span class="badge bg-light text-muted border" style="font-size: 0.65rem;"
                                              title="Original: @cita.FechaOriginal?.ToString("dd/MM/yyyy HH:mm")">
                                            <i class="bi bi-clock-history"></i> Reprogramada
                                        </span>
                                    </div>
                                }
                            </td>

                            <td class="text-center">
                                <div class="d-flex justify-content-center align-items-center gap-2">
                                    <button class="btn btn-sm btn-light border shadow-sm rounded-pill px-2"
                                            onclick="verDetalleCita('@nombreAlumno', '@cita.FechaHora', '@cita.Tipo', '@cita.Psicologo', '@cita.Estado')">
                                        <i class="bi bi-eye-fill text-primary"></i>
                                    </button>

                                    @if (cita.Estado == "Programada" || cita.Estado == "Ausente")
                                    {
                                        <button class="btn btn-sm btn-light border shadow-sm rounded-pill px-2"
                                                title="Reprogramar"
                                                onclick="abrirModalReprogramar('@cita.Id', '@cita.FechaHora?.ToString("yyyy-MM-ddTHH:mm")')">
                                            <i class="bi bi-calendar-range-fill text-info"></i>
                                        </button>
                                    }

                                    @if (cita.Estado == "Programada" || cita.Estado == "En Proceso" || cita.Estado == "Ausente")
                                    {
                                        string destinoController = (cita.Tipo == "Seguimiento") ? "Seguimiento" : "Fichas";
                                        bool esProceso = (cita.Estado == "En Proceso");
                                        string colorBoton = esProceso ? "#4299e1" : "#38b2ac";
                                        string textoBoton = esProceso ? "Continuar" : "Atender";
                                        string iconoBoton = esProceso ? "bi-pencil-square" : "bi-play-fill";

                                        <a asp-controller="@destinoController"
                                           asp-action="Create"
                                           asp-route-citaId="@cita.Id"
                                           class="btn btn-sm text-white px-3 shadow-sm"
                                           style="background: @colorBoton; border-radius: 8px;">
                                            <i class="bi @iconoBoton me-1"></i> @textoBoton
                                        </a>
                                    }

                                    @if (cita.Estado == "Atendida")
                                    {
                                        
                                        var citasConSeguimiento = ViewBag.CitasConSeguimiento as HashSet<string> ?? new HashSet<string>();
                                        bool yaTieneSeguimiento = citasConSeguimiento.Contains(cita.Id);

                                        if (yaTieneSeguimiento)
                                        {
                                            <a asp-controller="Seguimiento"
                                               asp-action="Create"
                                               asp-route-citaId="@cita.Id"
                                               class="btn btn-sm text-white px-3 shadow-sm"
                                               style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); border-radius: 8px;">
                                                <i class="bi bi-arrow-right-circle me-1"></i> Ir a Seguimiento
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm text-white px-3 shadow-sm"
                                                    style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 8px;"
                                                    onclick="confirmarIrASeguimiento('@cita.Id', '@cita.AlumnoId', '@nombreAlumno')">
                                                <i class="bi bi-plus-circle me-1"></i> Iniciar Seguimiento
                                            </button>
                                        }
                                    }

                                    <button type="button" class="btn btn-outline-danger btn-sm border-0 rounded-circle"
                                            style="width: 32px; height: 32px; background: #fff5f5;"
                                            onclick="confirmarEliminacion('@cita.Id', '@nombreAlumno')">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
                $(document).ready(function(){

            
            $("#searchInput, #filterEstado, #filterTipo, #dateStart, #dateEnd").on("keyup change", function() {
                var search = $("#searchInput").val().toLowerCase();
                var estado = $("#filterEstado").val();
                var tipo = $("#filterTipo").val();

                
                var start = $("#dateStart").val() ? new Date($("#dateStart").val()) : null;
                var end = $("#dateEnd").val() ? new Date($("#dateEnd").val()) : null;

                
                if(end) end.setHours(23, 59, 59, 999);

                $("#citasTable tbody tr").each(function() {
                    var row = $(this);
                    var text = row.text().toLowerCase();
                    var rowEstado = row.data("estado");
                    var rowTipo = row.data("tipo");

                   
                    var fechaTexto = row.find("td:first").text().trim().split(' ')[0]; 
                    var partes = fechaTexto.split('/');
                    var rowDate = new Date(partes[2], partes[1] - 1, partes[0]);

                    var matchSearch = text.indexOf(search) > -1;
                    var matchEstado = (estado === "todos" || rowEstado === estado);
                    var matchTipo = (tipo === "todos" || rowTipo === tipo);

                    
                    var matchDate = true;
                    if (start && rowDate < start) matchDate = false;
                    if (end && rowDate > end) matchDate = false;

                    row.toggle(matchSearch && matchEstado && matchTipo && matchDate);
                });
            });

            
            $("#clearDates").click(function(){
                $("#dateStart, #dateEnd").val("").trigger("change");
            });
        });


        function verDetalleCita(alumno, fecha, tipo, psicologo, estado) {
            Swal.fire({
                title: 'Detalle de la Cita',
                html: `
                    <div class="text-start p-2" style="font-size: 0.95rem;">
                        <p class="mb-1"><strong><i class="bi bi-person me-2"></i>Alumno:</strong> ${alumno}</p>
                        <p class="mb-1"><strong><i class="bi bi-calendar-event me-2"></i>Fecha:</strong> ${fecha}</p>
                        <p class="mb-1"><strong><i class="bi bi-tags me-2"></i>Tipo:</strong> ${tipo}</p>
                        <p class="mb-1"><strong><i class="bi bi-person-badge me-2"></i>Psicólogo:</strong> ${psicologo}</p>
                        <p class="mb-0"><strong><i class="bi bi-info-circle me-2"></i>Estado:</strong> ${estado}</p>
                    </div>`,
                icon: 'info',
                confirmButtonColor: '#764ba2',
                borderRadius: '15px'
            });
        }




                function abrirModalReprogramar(id, fechaActual) {
            Swal.fire({
                title: 'Reprogramar Cita',
                html: `
                    <div class="text-start">
                        <label class="form-label small fw-bold">Nueva Fecha y Hora:</label>
                        <input type="datetime-local" id="swal-new-date" class="form-control mb-3" value="${fechaActual}">
                        <label class="form-label small fw-bold">Motivo del cambio:</label>
                        <textarea id="swal-reason" class="form-control" rows="2" placeholder="Opcional..."></textarea>
                    </div>`,
                showCancelButton: true,
                confirmButtonText: 'Confirmar Cambio',
                confirmButtonColor: '#764ba2',
                preConfirm: () => {
                    return {
                        citaId: id,
                        nuevaFecha: document.getElementById('swal-new-date').value,
                        motivo: document.getElementById('swal-reason').value
                    }
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("Reprogramar", "Citas")', result.value, function(res) {
                        if(res.success) {
                            Swal.fire('¡Actualizado!', 'La cita ha sido reprogramada.', 'success')
                                .then(() => location.reload());
                        } else {
                            Swal.fire('Error', res.message, 'error');
                        }
                    });
                }
            });
        }


                function confirmarEliminacion(id, nombre) {
            
            Swal.fire({
                title: '¿Eliminar cita?',
                text: "Esta acción iniciará el proceso de borrado para el alumno: " + nombre,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#764ba2', 
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, continuar',
                cancelButtonText: 'Cancelar',
                borderRadius: '15px'
            }).then((result) => {
                if (result.isConfirmed) {

                    
                    Swal.fire({
                        title: '¿ESTÁS COMPLETAMENTE SEGURO?',
                        text: "Se eliminará la cita Y TODA LA FICHA diagnóstica/seguimiento asociada. Esta acción NO se puede deshacer.",
                        icon: 'error',
                        showCancelButton: true,
                        confirmButtonColor: '#d33', 
                        cancelButtonColor: '#6c757d',
                        confirmButtonText: 'SÍ, ELIMINAR TODO',
                        cancelButtonText: 'Me arrepentí',
                        borderRadius: '15px'
                    }).then((finalResult) => {
                        if (finalResult.isConfirmed) {
                            
                            $.post('@Url.Action("Delete", "Citas")', { id: id }, function(res) {
                                if(res.success) {
                                    Swal.fire({
                                        title: 'Eliminado',
                                        text: 'El registro ha sido removido de Base de Datos correctamente.',
                                        icon: 'success',
                                        borderRadius: '15px'
                                    }).then(() => location.reload());
                                } else {
                                    Swal.fire('Error', res.message || 'No se pudo eliminar.', 'error');
                                }
                            }).fail(function() {
                                Swal.fire('Error', 'Hubo un fallo en la conexión con el servidor.', 'error');
                            });
                        }
                    });
                }
            });
        }



                function confirmarIrASeguimiento(citaId, alumnoId, nombre) {
            Swal.fire({
                title: '¿Crear Ficha de Seguimiento?',
                text: `La cita de ${nombre} ya finalizó. ¿Deseas iniciar su ficha de seguimiento ahora?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#764ba2',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, ir a Seguimiento',
                cancelButtonText: 'Después',
                borderRadius: '15px'
            }).then((result) => {
                if (result.isConfirmed) {
                    
                    window.location.href = `/Seguimiento/Create?citaId=${citaId}`;
                }
            });
        }


    </script>
}