@model Toni_Real_Vicens_Sistema.Models.Cita

<h2>Nueva Cita</h2>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label>Alumno</label>
        <select asp-for="AlumnoId" class="form-select">
            <option value="">-- Seleccione --</option>
            @foreach (var a in ViewBag.Alumnos)
            {
                <option value="@a.Id">
                    @a.Apellidos @a.Nombres - @a.DNI
                </option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Fecha y Hora</label>
        <input asp-for="FechaHora" type="datetime-local" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Tipo</label>
        <select asp-for="Tipo" class="form-select">
            <option value="Evaluación">Evaluación</option>
            <option value="Seguimiento">Seguimiento</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Psicólogo</label>
        <input asp-for="Psicologo" class="form-control" />
    </div>

    <button class="btn btn-primary">Guardar</button>
</form>