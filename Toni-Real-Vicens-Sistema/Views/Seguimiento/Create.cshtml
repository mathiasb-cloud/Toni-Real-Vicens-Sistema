@model Toni_Real_Vicens_Sistema.Models.FichaSeguimiento

@{
    ViewData["Title"] = "Ficha de Seguimiento";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-white py-4 border-0">
            <h3 class="text-center fw-bold" style="color: #891c75;">Ficha de Seguimiento</h3>
            
            <div class="card-body bg-light rounded-3 my-3 border">
                <div class="row text-center small">
                    <div class="col-md-3 border-end"><strong>Estudiante:</strong><br>@ViewBag.AlumnoNombre</div>
                    <div class="col-md-2 border-end"><strong>DNI:</strong><br>@ViewBag.DNI</div>
                    <div class="col-md-2 border-end"><strong>Grado:</strong><br>@ViewBag.Grado</div>
                    <div class="col-md-3 border-end"><strong>Psicólogo Asignado:</strong><br><span class="text-primary fw-bold">@ViewBag.Psicologo</span></div>
                    <div class="col-md-2"><strong>Fecha de Ficha:</strong><br>@DateTime.Now.ToString("dd/MM/yyyy")</div>
                </div>
            </div>

            <div class="stepper-wrapper d-flex justify-content-between mt-4">
                <div class="stepper-item active" id="step-i-1">
                    <div class="step-counter">1</div>
                    <div class="step-name d-none d-md-block">Responsable / Dx</div>
                </div>
                <div class="stepper-item" id="step-i-2">
                    <div class="step-counter">2</div>
                    <div class="step-name d-none d-md-block">Psicoedu. / Eval.</div>
                </div>
                <div class="stepper-item" id="step-i-3">
                    <div class="step-counter">3</div>
                    <div class="step-name d-none d-md-block">Terapias / Visitas</div>
                </div>
                <div class="stepper-item" id="step-i-4">
                    <div class="step-counter">4</div>
                    <div class="step-name d-none d-md-block">Interconsulta</div>
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            <form asp-controller="Seguimiento" asp-action="Create" id="msform" method="post">
                <input type="hidden" asp-for="AlumnoId" />
                <input type="hidden" asp-for="CitaId" />
                <input type="hidden" asp-for="Id" />

                <section class="step-section" id="step-1">
                    <h5 class="fw-bold mb-3 border-bottom pb-2">1. Responsable y Diagnóstico (Dx)</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Forma de Ingreso</label>
                            <input asp-for="FormasIngreso" class="form-control" placeholder="Ej. Derivación Escolar" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Psicólogo Responsable</label>
                            <input asp-for="Psicologo" class="form-control bg-light" readonly />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Motivo</label>
                            <input asp-for="Motivo" class="form-control" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Diagnóstico Nosológico</label>
                            <input asp-for="DxNosologico" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold">Código</label>
                            <input asp-for="DxCodigo" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-bold">Nivel</label>
                            <select asp-for="DxNivel" class="form-select">
                                <option value="LEVE">LEVE</option>
                                <option value="MODERADO">MODERADO</option>
                                <option value="SEVERO">SEVERO</option>
                            </select>
                        </div>
                    </div>
                </section>

                <section class="step-section d-none" id="step-2">
                    <h5 class="fw-bold mb-3 border-bottom pb-2">2. Psicoeducación y Evaluaciones</h5>
                    <div class="row g-3">
                        <p class="fw-bold mb-0">Psicoeducación</p>
                        @for (int i = 1; i <= 3; i++)
                        {
                            <div class="col-md-4">
                                <label class="form-label small">Sesión @i</label>
                                <input type="date" name="Psicoeducacion@i" class="form-control" />
                            </div>
                        }

                        <p class="fw-bold mt-4 mb-0">Evaluaciones</p>
                        @for (int i = 1; i <= 5; i++)
                        {
                            <div class="col-md-2">
                                <label class="form-label small">Eval @i</label>
                                <input type="date" name="Evaluacion@i" class="form-control" />
                            </div>
                        }
                    </div>
                </section>

                <section class="step-section d-none" id="step-3">
                    <h5 class="fw-bold mb-3 border-bottom pb-2">3. Tratamiento: Terapias y Visitas</h5>
                    <div class="row g-3">
                        <p class="fw-bold mb-0">Terapia Individual</p>
                        <div class="row row-cols-2 row-cols-md-4 g-2">
                            @for (int i = 1; i <= 8; i++)
                            {
                                <div class="col mb-2">
                                    <label class="form-label small">Sesión @i</label>
                                    <input type="date" name="TerapiaInd@i" class="form-control form-control-sm" />
                                </div>
                            }
                        </div>

                        <div class="col-12"><hr /></div>

                        <div class="col-md-8">
                            <p class="fw-bold mb-2">Terapia Familiar</p>
                            <div class="row">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <div class="col">
                                        <label class="form-label small">@i</label>
                                        <input type="date" name="TerapiaFam@i" class="form-control form-control-sm" />
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="col-md-4">
                            <p class="fw-bold mb-2">Visita Domiciliaria</p>
                            <div class="row">
                                @for (int i = 1; i <= 3; i++)
                                {
                                    <div class="col">
                                        <label class="form-label small">@i</label>
                                        <input type="date" name="VisitaDom@i" class="form-control form-control-sm" />
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </section>

                <section class="step-section d-none" id="step-4">
                    <h5 class="fw-bold mb-3 border-bottom pb-2">4. Interconsulta y Cierre</h5>
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Institución de Derivación</label>
                            <input asp-for="InstitucionDerivacion" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Fecha de Derivación</label>
                            <input type="date" asp-for="FechaDerivacion" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Motivo de derivación</label>
                            <input asp-for="MotivoDerivacion" class="form-control" />
                        </div>
                        <div class="col-12 mt-4">
                            <div class="form-check form-switch p-3 border rounded bg-light">
                                <input class="form-check-input ms-0 me-3" type="checkbox" asp-for="IsFinalizada">
                                <label class="form-check-label fw-bold" for="IsFinalizada">Finalizar Seguimiento y Cerrar Cita</label>
                                <p class="text-muted small mb-0 ms-5">Al marcar esta opción, la ficha se considerará concluida y no podrá editarse.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <div class="d-flex justify-content-between align-items-center mt-5">
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-secondary px-4 d-none" id="prevBtn" onclick="nextPrev(-1)">Anterior</button>
                        <button type="button" class="btn btn-outline-info px-4 rounded-pill" id="saveProgressBtn" onclick="guardarAvance()">
                            <i class="bi bi-save me-2"></i>Guardar Avance
                        </button>
                    </div>
                    <button type="button" class="btn text-white px-5" style="background-color: #891c75;" id="nextBtn" onclick="nextPrev(1)">Siguiente</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Estilos del Stepper */
        .stepper-wrapper {
            position: relative;
            margin-bottom: 20px;
        }

        .stepper-item {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            flex: 1;
        }

            .stepper-item::before {
                position: absolute;
                content: "";
                border-bottom: 2px solid #ccc;
                width: 100%;
                top: 20px;
                left: -50%;
                z-index: 0;
            }

            .stepper-item:first-child::before {
                content: none;
            }

        .step-counter {
            position: relative;
            z-index: 10;
            display: flex;
            justify-content: center;
            align-items: center;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #ccc;
            color: white;
            margin-bottom: 6px;
            font-weight: bold;
        }

        .active .step-counter {
            background-color: #891c75;
        }

        .active .step-name {
            color: #891c75;
            font-weight: bold;
        }

        .completed .step-counter {
            background-color: #28a745;
        }
    </style>
}

@section Scripts {
    <script>
        var currentTab = 0;
        showTab(currentTab);

        function showTab(n) {
            var tabs = document.getElementsByClassName("step-section");
            tabs[n].classList.remove("d-none");

            
            if (n == 0) {
                document.getElementById("prevBtn").classList.add("d-none");
            } else {
                document.getElementById("prevBtn").classList.remove("d-none");
            }

            if (n == (tabs.length - 1)) {
                document.getElementById("nextBtn").innerHTML = "Guardar Ficha";
                document.getElementById("nextBtn").classList.replace("btn-primary", "btn-success");
            } else {
                document.getElementById("nextBtn").innerHTML = "Siguiente";
            }

            updateStepper(n);
        }

                function nextPrev(n) {
            var tabs = document.getElementsByClassName("step-section");

            
            if (n == 1 && !validateForm()) return false;

                       // Dentro de tu función nextPrev(n) cuando llega al final:
        if (currentTab + n >= tabs.length) {
            const isFinalizada = document.getElementById("IsFinalizada").checked;

            if (isFinalizada) {
                // Confirmación estilo profesional
                Swal.fire({
                    title: '¿Finalizar Atención?',
                    text: "Esta acción cerrará la ficha de seguimiento definitivamente.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#28a745', 
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sí, finalizar',
                    cancelButtonText: 'Cancelar',
                    borderRadius: '15px'
                }).then((result) => {
                    if (result.isConfirmed) {
                        
                        Swal.fire({
                            icon: 'success',
                            title: 'Ficha Finalizada',
                            showConfirmButton: false,
                            timer: 1500
                        }).then(() => {
                            document.getElementById("msform").submit();
                        });
                    }
                });
            } else {
                
                guardarAvance();
            }
            return false;
        }

            
            tabs[currentTab].classList.add("d-none");
            currentTab = currentTab + n;
            showTab(currentTab);
        }

        
        function enviarFormularioConAnimacion(mensaje) {
            Swal.fire({
                title: mensaje,
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            
            setTimeout(() => {
                document.getElementById("msform").submit();
            }, 800);
        }

        function updateStepper(n) {
            var i, items = document.getElementsByClassName("stepper-item");
            for (i = 0; i < items.length; i++) {
                items[i].classList.remove("active");
                if(i < n) items[i].classList.add("completed");
            }
            items[n].classList.add("active");
        }

        function validateForm() {

            return true;
        }



                        function guardarAvance() {
            
            Swal.fire({
                title: 'Guardando cambios...',
                text: 'Actualizando el progreso del seguimiento',
                icon: 'info',
                showConfirmButton: false,
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            
            setTimeout(() => {
                Swal.fire({
                    icon: 'success',
                    title: '¡Progreso Guardado!',
                    text: 'Los datos se han registrado correctamente.',
                    showConfirmButton: false,
                    timer: 1500,
                    borderRadius: '15px',
                    confirmButtonColor: '#891c75'
                }).then(() => {
                    
                    document.getElementById("msform").submit();
                });
            }, 1000);
        }



    </script>
}