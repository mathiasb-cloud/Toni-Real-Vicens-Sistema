@{
    ViewData["Title"] = "Dashboard";
    var nombre = Context.Session.GetString("UsuarioNombre") ?? "Usuario";
    var cargo = Context.Session.GetString("Cargo") ?? "Personal";
}

<div class="container mt-4 pb-5">
    <div class="row mb-4">
        <div class="col-12">
            <div class="p-4 p-md-5 text-white shadow-lg welcome-banner d-flex align-items-center justify-content-between">
                <div>
                    <span class="badge bg-white text-primary mb-2 px-3 py-2 rounded-pill shadow-sm">@cargo</span>
                    <h1 class="fw-bold mb-1">¡Qué bueno verte, @nombre!</h1>
                    <p class="opacity-75 mb-0">Aquí tienes el resumen psicopedagógico de hoy.</p>
                </div>
                <div class="d-none d-lg-block">
                    <div class="glass-clock text-center p-3">
                        <h4 class="mb-0 fw-bold" id="liveTime">00:00</h4>
                        <small class="opacity-75">@DateTime.Now.ToString("dd MMMM, yyyy")</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-6 col-md-3">
            <div class="stat-card p-3 shadow-sm border-0 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="icon-sm rounded-circle bg-soft-primary me-3 text-primary"><i class="bi bi-people"></i></div>
                    <div>
                        <h3 class="fw-bold mb-0">@ViewBag.TotalAlumnos</h3>
                        <small class="text-muted">Alumnos</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card p-3 shadow-sm border-0 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="icon-sm rounded-circle bg-soft-success me-3 text-success"><i class="bi bi-calendar-check"></i></div>
                    <div>
                        <h3 class="fw-bold mb-0">@ViewBag.CitasHoy</h3>
                        <small class="text-muted">Citas hoy</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card p-3 shadow-sm border-0 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="icon-sm rounded-circle bg-soft-warning me-3 text-warning"><i class="bi bi-file-earmark-text"></i></div>
                    <div>
                        <h3 class="fw-bold mb-0">@ViewBag.TotalFichas</h3>
                        <small class="text-muted">Expedientes</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card p-3 shadow-sm border-0 bg-white h-100">
                <div class="d-flex align-items-center">
                    <div class="icon-sm rounded-circle bg-soft-danger me-3 text-danger"><i class="bi bi-palette"></i></div>
                    <div>
                        <h3 class="fw-bold mb-0">@ViewBag.TotalTalleres</h3>
                        <small class="text-muted">En Talleres</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 20px;">
                <h5 class="fw-bold mb-4 text-dark">Distribución por Niveles (Inicial, Primaria, Secundaria)</h5>
                <canvas id="activityChart" style="max-height: 300px;"></canvas>
            </div>
        </div>

        <div class="col-lg-4">
            <h5 class="fw-bold mb-3">Accesos Directos</h5>
            <div class="row g-3">
                <div class="col-6 col-lg-12">
                    <a asp-controller="Alumnos" asp-action="Index" class="text-decoration-none">
                        <div class="quick-access-item p-3 d-flex align-items-center bg-white shadow-sm rounded-4 border-start border-4 border-info">
                            <i class="bi bi-person-badge-fill fs-4 text-info me-3"></i>
                            <span class="fw-bold text-dark">Alumnos</span>
                        </div>
                    </a>
                </div>
                <div class="col-6 col-lg-12">
                    <a asp-controller="Citas" asp-action="Index" class="text-decoration-none">
                        <div class="quick-access-item p-3 d-flex align-items-center bg-white shadow-sm rounded-4 border-start border-4 border-warning">
                            <i class="bi bi-calendar-check-fill fs-4 text-warning me-3"></i>
                            <span class="fw-bold text-dark">Citas</span>
                        </div>
                    </a>
                </div>
                <div class="col-6 col-lg-12">
                    <a asp-controller="Fichas" asp-action="Index" class="text-decoration-none">
                        <div class="quick-access-item p-3 d-flex align-items-center bg-white shadow-sm rounded-4 border-start border-4 border-primary">
                            <i class="bi bi-file-earmark-medical-fill fs-4 text-primary me-3"></i>
                            <span class="fw-bold text-dark">Expedientes</span>
                        </div>
                    </a>
                </div>
                <div class="col-6 col-lg-12">
                    <a asp-controller="Fichas" asp-action="Index" class="text-decoration-none">
                        <div class="quick-access-item p-3 d-flex align-items-center bg-white shadow-sm rounded-4 border-start border-4 border-dark">
                            <i class="bi bi-file-earmark-text-fill fs-4 text-dark me-3"></i>
                            <span class="fw-bold text-dark">Fichas</span>
                        </div>
                    </a>
                </div>
            </div>
        </div>


        <div class="row g-4 mt-2">
            <div class="col-12">
                <div class="card border-0 shadow-sm p-4" style="border-radius: 20px; background-color: #ffffff;">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <div>
                            <h5 class="fw-bold mb-0 text-dark">
                                <i class="bi bi-calendar3 me-2 text-primary"></i>Agenda Semanal de Citas
                            </h5>
                            <p class="text-muted small mb-0">Visualización de carga de trabajo para los próximos 7 días.</p>
                        </div>
                        <a asp-controller="Citas" asp-action="Agenda" class="btn btn-sm btn-light rounded-pill px-3 fw-bold shadow-sm">
                            Ver Agenda Completa
                        </a>
                    </div>

                    <div class="row row-cols-2 row-cols-md-4 row-cols-lg-7 g-3" id="weeklySchedule">
                    </div>
                </div>
            </div>
        </div>
    

        



    </div>
</div>

<style>
    body {
        background-color: #f7f9fc;
    }

    .welcome-banner {
        background: linear-gradient(135deg, #891c75 0%, #667eea 100%);
        border-radius: 30px;
    }

    .glass-clock {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        min-width: 150px;
        border: 1px solid rgba(255,255,255,0.3);
    }

    .stat-card {
        border-radius: 20px;
        transition: transform 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-5px);
        }

    .icon-sm {
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    .bg-soft-primary {
        background-color: #eef2ff;
    }

    .bg-soft-success {
        background-color: #ecfdf5;
    }

    .bg-soft-warning {
        background-color: #fffbeb;
    }

    .bg-soft-danger {
        background-color: #fef2f2;
    }

    .quick-access-item {
        transition: all 0.2s ease;
    }

        .quick-access-item:hover {
            background-color: #f1f5f9 !important;
            transform: translateX(5px);
        }

    canvas {
        width: 100% !important;
    }

    .day-card {
        background: #f8fafc;
        border-radius: 16px;
        padding: 15px 10px;
        text-align: center;
        transition: all 0.3s ease;
        border: 2px solid transparent;
        height: 100%;
    }

        .day-card:hover {
            transform: translateY(-5px);
            background: #ffffff;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        .day-card.today {
            border-color: #891c75;
            background: #fff5fd;
        }

    .day-name {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        color: #94a3b8;
        display: block;
        margin-bottom: 5px;
    }

    .day-number {
        font-size: 1.5rem;
        font-weight: 800;
        display: block;
        color: #1e293b;
        line-height: 1;
        margin-bottom: 10px;
    }

    .citas-badge {
        font-size: 0.7rem;
        padding: 4px 10px;
        border-radius: 20px;
        font-weight: 700;
    }

    .has-citas {
        background: #891c75;
        color: white;
    }

    .no-citas {
        background: #e2e8f0;
        color: #64748b;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function updateTime() {
            const now = new Date();
            document.getElementById('liveTime').innerText = now.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
        }
        setInterval(updateTime, 1000);
        updateTime();

        // Recuperar datos reales del ViewBag
        const datosNiveles = @Html.Raw(Json.Serialize(ViewBag.DataNiveles));

        const ctx = document.getElementById('activityChart').getContext('2d');
        new Chart(ctx, {
            type: 'line', // Restaurado a LINEA como el diseño original
            data: {
                labels: ['Inicial', 'Primaria', 'Secundaria'],
                datasets: [{
                    label: 'Alumnos por Nivel',
                    data: datosNiveles,
                    borderColor: '#891c75',
                    backgroundColor: 'rgba(137, 28, 117, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 6,
                    pointBackgroundColor: '#891c75',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 },
                        grid: { color: '#f0f0f0' }
                    },
                    x: { grid: { display: false } }
                }
            }
        });



                         function initWeeklySchedule() {
            const container = document.getElementById('weeklySchedule');
            const hoy = new Date();
            const nombresDias = ["Dom", "Lun", "Mar", "Mié", "Jue", "Vie", "Sáb"];

            
            const conteoRealSemanal = @Html.Raw(Json.Serialize(ViewBag.ConteoSemanal));

            container.innerHTML = ""; 

            for (let i = 0; i < 7; i++) {
                let fechaIterada = new Date();
                fechaIterada.setDate(hoy.getDate() + i);

                let diaNombre = nombresDias[fechaIterada.getDay()];
                let diaNum = fechaIterada.getDate();
                let esHoy = i === 0;

                
                let count = conteoRealSemanal[i];
                let badgeClass = count > 0 ? "has-citas" : "no-citas";
                let label = count > 0 ? `${count} Citas` : "Disponible";

                const col = document.createElement('div');
                col.className = 'col';
                col.innerHTML = `
                    <div class="day-card ${esHoy ? 'today shadow-sm' : ''}">
                        <span class="day-name">${diaNombre}</span>
                        <span class="day-number">${diaNum}</span>
                        <span class="citas-badge ${badgeClass}">
                            ${count > 0 ? '<i class="bi bi-dot"></i> ' : ''}${label}
                        </span>
                    </div>
                `;
                container.appendChild(col);
            }
        }

        
        initWeeklySchedule();
    </script>
}