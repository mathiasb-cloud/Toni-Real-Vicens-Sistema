@model Toni_Real_Vicens_Sistema.Models.Alumno

<style>
    .card-custom {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }

    .section-title {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #667eea;
        margin-bottom: 1.5rem;
        border-bottom: 2px solid #f0f4f8;
        padding-bottom: 5px;
        font-weight: bold;
    }

    .data-label {
        font-size: 0.75rem;
        color: #a0aec0;
        text-transform: uppercase;
        font-weight: bold;
        display: block;
    }

    .data-value {
        font-size: 1rem;
        color: #2d3748;
        font-weight: 500;
        padding: 0.5rem 0;
        border-bottom: 1px solid #edf2f7;
        display: block;
        margin-bottom: 1rem;
    }
</style>

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card card-custom">
                <div class="card-body p-4 p-md-5">

                    <div class="d-flex justify-content-between align-items-center mb-5">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 50px; height: 50px;">
                                <i class="bi bi-person-badge fs-4"></i>
                            </div>
                            <div>
                                <h3 class="fw-bold mb-0">@Model.Nombres @Model.Apellidos</h3>
                                <p class="text-muted mb-0">DNI: @Model.DNI | Nivel: @Model.Nivel</p>
                            </div>
                        </div>
                        <span class="badge rounded-pill bg-success px-4 py-2">@Model.Estado</span>
                    </div>

                    <div class="section-title">1. Identidad y Ubicación</div>
                    <div class="row mb-4">
                        <div class="col-md-3"><span class="data-label">Grado</span><span class="data-value">@Model.Grado</span></div>
                        <div class="col-md-3"><span class="data-label">Sección</span><span class="data-value">@(Model.Seccion ?? "N/A")</span></div>
                        <div class="col-md-3"><span class="data-label">Sexo</span><span class="data-value">@Model.Sexo</span></div>
                        <div class="col-md-3"><span class="data-label">F. Nacimiento</span><span class="data-value">@Model.FechaNacimiento?.ToShortDateString()</span></div>
                    </div>

                    <div class="section-title">2. Salud y Discapacidad</div>
                    <div class="row mb-4">
                        <div class="col-md-4"><span class="data-label">¿Posee Discapacidad?</span><span class="data-value">@Model.Discapacidad</span></div>
                        <div class="col-md-4"><span class="data-label">Tipo</span><span class="data-value">@(Model.TipoDiscapacidad ?? "Ninguno")</span></div>
                        <div class="col-md-4"><span class="data-label">Detalle</span><span class="data-value">@(Model.OtraDiscapacidad ?? "Sin detalles")</span></div>
                    </div>

                    <div class="section-title">3. Contacto y Familia</div>
                    <div class="row mb-4">
                        <div class="col-md-6"><span class="data-label">Tutor Responsable</span><span class="data-value">@Model.Tutor</span></div>
                        <div class="col-md-6"><span class="data-label">Dirección</span><span class="data-value">@Model.Direccion</span></div>
                        <div class="col-md-4"><span class="data-label">Celular Tutor</span><span class="data-value">@(Model.TutorTelefono ?? "-")</span></div>
                        <div class="col-md-4"><span class="data-label">Celular Alumno</span><span class="data-value">@(Model.TelefonoAlumno ?? "-")</span></div>
                        <div class="col-md-4"><span class="data-label">Emergencias</span><span class="data-value">@(Model.TelefonoEmergencia ?? "-")</span></div>
                    </div>

                    <div class="d-flex justify-content-between mt-5">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Volver al Listado</a>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-5">Editar esta Ficha</a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>