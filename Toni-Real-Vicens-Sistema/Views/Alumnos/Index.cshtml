@model List<Toni_Real_Vicens_Sistema.Models.Alumno>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: #4a5568;">
                <i class="bi bi-people-fill me-2" style="color: #667eea;"></i> Registro de Alumnos
            </h2>
            <p class="text-muted small mb-0">Gestión de datos personales y académicos de los estudiantes.</p>
        </div>
        <a asp-action="Create" class="btn text-white px-4 py-2 shadow-sm"
           style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px;">
            <i class="bi bi-person-plus-fill me-2"></i> Nuevo Alumno
        </a>
    </div>

    <div class="card border-0 shadow-sm mb-4" style="border-radius: 15px;">
        <div class="card-body p-3">
            <div class="input-group">
                <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="alumnoSearch" class="form-control border-0 shadow-none" placeholder="Buscar por DNI, Nombre o Apellido...">
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 15px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="alumnosTable">
                <thead style="background-color: #f8faff;">
                    <tr>
                        <th class="ps-4 py-3 text-secondary small border-0">DNI</th>
                        <th class="py-3 text-secondary small border-0">APELLIDOS Y NOMBRES</th>
                        <th class="py-3 text-secondary small border-0 text-center">GRADO / SECCIÓN</th>
                        <th class="py-3 text-secondary small border-0 text-center">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var alumno in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark">@alumno.DNI</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-light d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px; color: #667eea;">
                                        <i class="bi bi-person"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold">@alumno.Apellidos, @alumno.Nombres</div>
                                        <div class="text-muted small">Dni: @alumno.DNI</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border px-3 py-2" style="border-radius: 8px;">
                                    @alumno.Grado "@alumno.Seccion"
                                </span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@alumno.Id" class="btn btn-sm btn-outline-primary border-0 rounded-circle" style="width: 35px; height: 35px;">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <button onclick="confirmarEliminarAlumno('@alumno.Id', '@alumno.Nombres')" class="btn btn-sm btn-outline-danger border-0 rounded-circle" style="width: 35px; height: 35px;">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // 1. ALERTA DE ÉXITO AL REGISTRAR/EDITAR
            // Captura el mensaje enviado desde el controlador mediante TempData
            var successMessage = '@TempData["SuccessMessage"]';
            if (successMessage) {
                Swal.fire({
                    title: '¡Operación Exitosa!',
                    text: successMessage,
                    icon: 'success',
                    confirmButtonColor: '#764ba2',
                    borderRadius: '15px'
                });
            }

            // 2. BUSCADOR EN TIEMPO REAL
            $("#alumnoSearch").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#alumnosTable tbody tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });

        // 3. ELIMINACIÓN CON DOBLE CONFIRMACIÓN (Seguridad Reforzada)
        function confirmarEliminarAlumno(id, nombre) {
            // Primera Advertencia
            Swal.fire({
                title: '¿Eliminar Alumno?',
                text: "Estás por iniciar el proceso para borrar a: " + nombre,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#764ba2', // Color morado consistente
                confirmButtonText: 'Sí, continuar',
                cancelButtonText: 'Cancelar',
                borderRadius: '15px'
            }).then((result) => {
                if (result.isConfirmed) {

                    // Segunda Advertencia (Zona de Peligro)
                    Swal.fire({
                        title: '¡DETENTE Y CONFIRMA!',
                        text: "Si eliminas a este alumno, también se perderá su historial y datos vinculados. Esta acción es IRREVERSIBLE.",
                        icon: 'error',
                        showCancelButton: true,
                        confirmButtonColor: '#d33', // Rojo de alerta crítica
                        confirmButtonText: 'SÍ, ELIMINAR PERMANENTEMENTE',
                        cancelButtonText: 'No, mantener registro',
                        borderRadius: '15px'
                    }).then((finalResult) => {
                        if (finalResult.isConfirmed) {
                            // Ejecución del borrado
                            $.post('@Url.Action("Delete", "Alumnos")', { id: id }, function(res) {
                                // Asumiendo que tu controlador devuelve un JSON de éxito
                                Swal.fire({
                                    title: 'Eliminado',
                                    text: 'El alumno ha sido removido del sistema.',
                                    icon: 'success',
                                    borderRadius: '15px'
                                }).then(() => location.reload());
                            }).fail(function() {
                                Swal.fire('Error', 'No se pudo completar la operación. Intente de nuevo.', 'error');
                            });
                        }
                    });
                }
            });
        }
    </script>
}