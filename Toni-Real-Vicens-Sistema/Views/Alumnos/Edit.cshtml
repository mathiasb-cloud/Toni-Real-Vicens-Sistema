@model Toni_Real_Vicens_Sistema.Models.Alumno

<style>
    .form-control-minimal {
        border: none;
        border-bottom: 2px solid #e2e8f0;
        border-radius: 0;
        padding: 0.75rem 0.5rem;
        background-color: transparent;
        transition: border-color 0.3s ease;
    }

        .form-control-minimal:focus {
            box-shadow: none;
            border-bottom-color: #667eea;
            background-color: #f8faff;
        }

    .card-custom {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }

    .section-title {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #a0aec0;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid #edf2f7;
        padding-bottom: 5px;
    }
</style>

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card card-custom">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex align-items-center mb-5">
                        <div class="bg-warning text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 50px; height: 50px;">
                            <i class="bi bi-pencil-square fs-4"></i>
                        </div>
                        <div>
                            <h3 class="fw-bold mb-0">Editar Datos del Estudiante</h3>
                            <p class="text-muted small mb-0">Modificando registro completo.</p>
                        </div>
                    </div>

                    <form asp-action="Edit" method="post" id="formAlumno">
                        <input type="hidden" asp-for="Id" />

                        <div class="section-title">1. Estado y Ubicación</div>
                        <div class="row g-4 mb-5">
                            <div class="col-md-3">
                                <label class="small fw-bold text-primary">Estado *</label>
                                <select asp-for="Estado" class="form-select form-control-minimal" required>
                                    <option value="Estudiante">Estudiante</option>
                                    <option value="Retirado">Retirado</option>
                                    <option value="Egresado">Egresado</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="small fw-bold">Nivel *</label>
                                <select asp-for="Nivel" id="selectNivel" class="form-select form-control-minimal" required>
                                    <option value="Inicial">Inicial</option>
                                    <option value="Primaria">Primaria</option>
                                    <option value="Secundaria">Secundaria</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="small fw-bold">Grado *</label>
                                <select asp-for="Grado" id="selectGrado" class="form-select form-control-minimal" required>
                                    <option value="@Model.Grado">@Model.Grado</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="small fw-bold">Sección</label>
                                <input asp-for="Seccion" class="form-control form-control-minimal" />
                            </div>
                        </div>

                        <div class="section-title">2. Identidad del Alumno</div>
                        <div class="row g-4 mb-5">
                            <div class="col-md-4"><label class="small fw-bold">Nombres *</label><input asp-for="Nombres" class="form-control form-control-minimal" required /></div>
                            <div class="col-md-4"><label class="small fw-bold">Apellidos *</label><input asp-for="Apellidos" class="form-control form-control-minimal" required /></div>
                            <div class="col-md-4"><label class="small fw-bold">DNI *</label><input asp-for="DNI" class="form-control form-control-minimal" maxlength="8" required /></div>
                            <div class="col-md-4"><label class="small fw-bold">Fecha Nacimiento *</label><input asp-for="FechaNacimiento" type="date" class="form-control form-control-minimal" required /></div>
                            <div class="col-md-4"><label class="small fw-bold">Sexo *</label><select asp-for="Sexo" class="form-select form-control-minimal"><option value="Masculino">Masculino</option><option value="Femenino">Femenino</option></select></div>
                            <div class="col-md-4"><label class="small fw-bold">¿Partida Registrada?</label><select asp-for="NacimientoRegistrado" class="form-select form-control-minimal"><option value="Sí">Sí</option><option value="No">No</option></select></div>
                        </div>

                        <div class="section-title">3. Salud y Discapacidad</div>
                        <div class="row g-4 mb-5">
                            <div class="col-md-4">
                                <label class="small fw-bold">¿Discapacidad? *</label>
                                <select asp-for="Discapacidad" id="selectDiscapacidad" class="form-select form-control-minimal" required>
                                    <option value="No">No</option>
                                    <option value="Sí">Sí</option>
                                </select>
                            </div>
                            <div class="col-md-4" id="divTipoD" style="display:none;">
                                <label class="small fw-bold text-primary">Tipo de Discapacidad</label>
                                <select asp-for="TipoDiscapacidad" id="selectTipoD" class="form-select form-control-minimal">
                                    <option value="">-- Seleccione --</option>
                                    <option value="Inteligencia DI">Inteligencia DI</option>
                                    <option value="Sordera">Sordera</option>
                                    <option value="Visual">Visual</option>
                                    <option value="Motora">Motora</option>
                                    <option value="Otro">Otro</option>
                                </select>
                            </div>
                            <div class="col-md-4" id="divOtroD" style="display:none;">
                                <label class="small fw-bold text-primary">Especifique</label>
                                <input asp-for="OtraDiscapacidad" class="form-control form-control-minimal" />
                            </div>
                        </div>

                        <div class="section-title">4. Familia y Contacto</div>
                        <div class="row g-4 mb-5">
                            <div class="col-md-6"><label class="small fw-bold">Tutor *</label><input asp-for="Tutor" class="form-control form-control-minimal" required /></div>
                            <div class="col-md-6"><label class="small fw-bold">Dirección *</label><input asp-for="Direccion" class="form-control form-control-minimal" required /></div>
                            <div class="col-md-4"><label class="small fw-bold">Teléfono Tutor</label><input asp-for="TutorTelefono" class="form-control form-control-minimal" /></div>
                            <div class="col-md-4"><label class="small fw-bold">Teléfono Alumno</label><input asp-for="TelefonoAlumno" class="form-control form-control-minimal" /></div>
                            <div class="col-md-4"><label class="small fw-bold">Emergencias</label><input asp-for="TelefonoEmergencia" class="form-control form-control-minimal" /></div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="text-muted text-decoration-none small"><i class="bi bi-chevron-left"></i> Cancelar</a>
                            <button type="submit" class="btn btn-dark px-5 shadow">Actualizar Registro</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            
            function cargarGrados(nivel, gradoActual) {
                var $grado = $('#selectGrado'); $grado.empty();
                var grados = { 'Inicial': ['3 años', '4 años', '5 años'], 'Primaria': ['1ro', '2do', '3ro', '4to', '5to', '6to'], 'Secundaria': ['1ro', '2do', '3ro', '4to', '5to'] };
                if (nivel && grados[nivel]) {
                    $.each(grados[nivel], function (i, v) { $grado.append(`<option value="${v}" ${v === gradoActual ? "selected" : ""}>${v}</option>`); });
                }
            }

            $('#selectNivel').change(function() { cargarGrados($(this).val(), ""); });

            
            function toggleDiscapacidad() {
                if ($('#selectDiscapacidad').val() === 'Sí') { $('#divTipoD').show(); } else { $('#divTipoD, #divOtroD').hide(); }
            }
            $('#selectDiscapacidad').change(toggleDiscapacidad);
            toggleDiscapacidad(); 
        });
    </script>
}