@model List<Toni_Real_Vicens_Sistema.Models.Alumno>

@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <tr>
            <td>
                <input type="checkbox" class="form-check-input alumno-check" value="@item.Id">
            </td>
            <td>
                <div class="fw-bold">@item.Apellidos, @item.Nombres</div>
                <small class="text-muted">@item.Nivel</small>
            </td>
            <td>@item.DNI</td>
            <td><span class="badge bg-info text-dark">@item.Grado</span></td>
            <td>@(string.IsNullOrEmpty(item.Seccion) ? "-" : item.Seccion)</td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="5" class="text-center p-4">
            <i class="bi bi-exclamation-triangle text-warning"></i> No se encontraron alumnos con esos filtros.
        </td>
    </tr>
}